lt() {
    local level=2
    local path="."
    local show_files=false
    local unfilter=false
    local all_hidden=false

    # Standard Help Text
    usage() {
        echo "Usage: lt [level] [options] [path]"
        echo "Options:"
        echo "  -f, --files     Include files"
        echo "  -a, --all       Include hidden"
        echo "  -u, --unfilter  No ignores (show .git/node_modules)"
        echo "  -h, --help      Show this help"
    }

    # Manual Parsing Loop (Handles -af and mixed order)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) usage; return 0 ;;
            -[a-zA-Z]*) 
                local optstring="${1#-}"
                for (( i=0; i<${#optstring}; i++ )); do
                    case "${optstring:$i:1}" in
                        f) show_files=true ;;
                        a) all_hidden=true ;;
                        u) unfilter=true ;;
                    esac
                done
                shift ;;
            [0-9]*) level="$1"; shift ;;
            *) path="$1"; shift ;;
        esac
    done

    # Build the eza command
    local cmd=("eza" "--tree" "--icons" "--classify" "--color=always" "--group-directories-first")
    
    cmd+=("--level=$level")
    
    [[ "$all_hidden" == true ]] && cmd+=("--all")
    [[ "$show_files" == false ]] && cmd+=("--only-dirs")
    
    # Logic for excluding node_modules/.git
    if [[ "$unfilter" == false ]]; then
        cmd+=("--ignore-glob=node_modules|.git|.cache|.DS_Store")
