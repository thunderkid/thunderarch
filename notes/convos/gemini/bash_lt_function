Here is a robust Bash function for your .bashrc or .zshrc. It uses a while loop to handle flags flexibly, ensuring you can pass levels and options in any order.

Bash
lt() {
    local level=2
    local args=("--tree" "--icons" "--color=always" "--group-directories-first" "--classify")
    local path="."

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                echo "Usage: lt [level] [options] [path]"
                echo "Options:"
                echo "  -f, --files       Include files (defaults to directories only)"
                echo "  -a, --all         Include hidden files"
                echo "  -u, --unfilter    No ignores (show .git, node_modules, etc.)"
                return 0
                ;;
            -f|--files)
                # By default we'll add -d later if -f isn't passed
                local show_files=true
                shift
                ;;
            -a|--all)
                args+=("--all")
                shift
                ;;
            -u|--unfilter)
                args+=("--no-ignore")
                shift
                ;;
            [0-9]*)
                level="$1"
                shift
                ;;
            *)
                path="$1"
                shift
                ;;
        esac
    done

    # If -f wasn't provided, restrict to directories only
    if [[ -z "$show_files" ]]; then
        args+=("--only-dirs")
    fi

    # Execute eza
    eza "${args[@]}" --level="$level" "$path"
}
