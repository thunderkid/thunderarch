The Optimized Script (~/.config/waybar/get_wifi.sh)
This version uses nmcli -g (terse/grouped mode) to pull only the data for the currently active interface. It's essentially instant.

Bash
#!/bin/bash

# Get the active Wi-Fi interface name (usually wlan0)
INTERFACE=$(nmcli -t -f DEVICE,TYPE device | grep ':wifi$' | cut -d':' -f1 | head -n1)

if [ -z "$INTERFACE" ]; then
    echo '{"text": "Disconnected ⚠", "class": "disconnected"}'
    exit 0
fi

# Pull SSID and Signal Strength directly from the active device properties
# This avoids a 'rescan' and is nearly instantaneous
ESSID=$(nmcli -t -f GENERAL.CONNECTION device show "$INTERFACE" | cut -d':' -f2)
SIGNAL=$(nmcli -t -f IP4.ADDRESS,GENERAL.STATE device show "$INTERFACE" | grep 'STATE' | awk '{print $2}') 
# Alternative for signal: pull from /proc/net/wireless for zero-latency
SIGNAL_PERC=$(grep "$INTERFACE" /proc/net/wireless | awk '{print int($3 * 100 / 70)}')

# If ESSID is empty, we aren't actually connected to a network
if [ -z "$ESSID" ]; then
    echo '{"text": "Connecting... ", "class": "connecting"}'
else
    # Output in JSON format so Waybar can use it effectively
    echo "{\"text\": \"$ESSID ($SIGNAL_PERC%) \", \"tooltip\": \"Interface: $INTERFACE\"}"
fi
