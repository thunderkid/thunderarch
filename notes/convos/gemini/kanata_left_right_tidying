Key Changes
Syntax Tidying: Grouped aliases and used consistent spacing.

Removed Chords: Deleted the df-esc logic.

Bilateral Guardrails: Switched to tap-hold-release-keys. This means @sft_f will only trigger Shift if you strike it and then hit a key listed in the $right-hand-keys variable. If you just type "f" quickly, it remains "f".

Left Alt/Right Shift: Cleaned up the alt_esc and rsft_caps aliases for better readability.

Lisp
(defcfg
  process-unmapped-keys yes
)

(defsrc
  u i o
  a s d f   h j k l ;
  m , .
  lalt caps rsft spc
)

(defvar
  tap-time 200
  hold-time 200

  ;; Define the hand groups for bilateral guardrails
  left-hand-keys  (a s d f)
  right-hand-keys (h j k l ; u i o m , .)
)

(defalias
  ;; Left hand mods (Guardrail: only active when used with right-hand keys)
  ctl_a (tap-hold-release-keys $tap-time $hold-time a lctl $right-hand-keys)
  alt_s (tap-hold-release-keys $tap-time $hold-time s lalt $right-hand-keys)
  met_d (tap-hold-release-keys $tap-time $hold-time d lmet $right-hand-keys)
  sft_f (tap-hold-release-keys $tap-time $hold-time f lsft $right-hand-keys)

  ;; Right hand mods (Guardrail: only active when used with left-hand keys)
  sft_j (tap-hold-release-keys $tap-time $hold-time j rsft $left-hand-keys)
  met_k (tap-hold-release-keys $tap-time $hold-time k rmet $left-hand-keys)
  alt_l (tap-hold-release-keys $tap-time $hold-time l ralt $left-hand-keys)
  ctl_sc (tap-hold-release-keys $tap-time $hold-time ; rctl $left-hand-keys)

  ;; Thumb Keys & Utility
  spc_nav   (tap-hold 150 200 spc (layer-toggle nav-layer))
  alt_esc   (tap-hold 150 200 esc lalt)
  rsft_caps (tap-hold 150 200 caps rsft)
)

(deflayer default
  u       i       o
  @ctl_a  @alt_s  @met_d  @sft_f    h  @sft_j  @met_k  @alt_l  @ctl_sc
  m       ,       .
  @alt_esc bspc @rsft_caps @spc_nav
)

(deflayer nav-layer
  pgup  up    pgdn
  _     _     _     _     bspc  left  down  right  del
  home  _     end
  _     _     _     _
)
