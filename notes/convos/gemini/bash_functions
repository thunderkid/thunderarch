lt() {
  local lvl=2
  local args=()
  local eza_flags=("--lhF" "--git" "--tree" "--color=always" "--icons" "--only-dirs" "--group-directories-first")
  local ignore_pattern="--ignore-glob=.git|node_modules|__pycache__|.DS_Store"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        echo "Usage: lt [level] [options] [path]"
        echo "Options:"
        echo "  -f, --files     Include files"
        echo "  -a, --all       Include hidden"
        echo "  -u, --unfilter  No ignores (show .git/node_modules)"
        echo "  -s [term]       Search/Filter tree for a term"
        return 0 ;;
      -f|--files)    eza_flags=("${eza_flags[@]/--only-dirs/}") ;;
      -a|--all)      eza_flags+=("--all") ;;
      -u|--unfilter) ignore_pattern="" ;;
      -s|--search)   shift; eza_flags+=("--ignore-glob=^((?!$1).)*$") ;;
      [0-9])         lvl="$1" ;;
      *)             args+=("$1") ;;
    esac
    shift
  done

  eza "${eza_flags[@]}" $ignore_pattern --level="$lvl" "${args[@]}"
}
Pro-Tip: Why we avoid grep for Trees
When you pipe to grep, you lose the "edge" characters (├──, └──) that make a tree a tree. By using eza's internal filtering (as shown in the -s flag above), eza handles the pruning of the tree for you, ensuring the output remains valid ASCII art.

