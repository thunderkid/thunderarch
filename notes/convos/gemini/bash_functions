The Corrected, Error-Free Tree Function
Bash
lt() {
  local lvl=2
  local show_files=false
  local show_all=false
  local unfilter=false
  local search_term=""
  local args=()

  # 1. Parse Arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        echo "Usage: lt [level] [options] [path]"
        echo "Options:"
        echo "  -f, --files     Include files (default is dirs only)"
        echo "  -a, --all       Include hidden files/folders"
        echo "  -u, --unfilter  Disable all ignores (.git, node_modules, etc.)"
        echo "  -s [term]       Search/Filter tree for a term"
        echo "  [0-9]           Set depth (default 2)"
        return 0 ;;
      -f|--files)    show_files=true ;;
      -a|--all)      show_all=true ;;
      -u|--unfilter) unfilter=true ;;
      -s|--search)   shift; search_term="$1" ;;
      [0-9])         lvl="$1" ;;
      *)             args+=("$1") ;;
    esac
    shift
  done

  # 2. Build Flag Array Dynamically (No empty strings)
  local cmd_flags=("-lhF" "--git" "--tree" "--color=always" "--icons" "--group-directories-first")
  
  if [ "$show_files" = false ]; then
    cmd_flags+=("--only-dirs")
  fi

  if [ "$show_all" = true ]; then
    cmd_flags+=("--all")
  fi

  # 3. Handle Ignores and Search
  local final_args=("--level=$lvl")
  
  if [ "$unfilter" = false ]; then
    final_args+=("--ignore-glob=.git|node_modules|__pycache__|.DS_Store")
  fi

  if [ -n "$search_term" ]; then
    # Case-insensitive search that prunes the tree to matches
    final_args+=("--recurse" "--ignore-glob=^((?i)(?!${search_term}).)*$")
  fi

  # 4. Execute
  eza "${cmd_flags[@]}" "${final_args[@]}" "${args[@]}"
}
